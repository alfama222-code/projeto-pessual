// This file is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  criadoEm  DateTime @default(now())
}

model Produto {
  id          String @id @default(uuid())
  name        String
  type        String
  price       Float
  description String
  image       String
}

model Pedido {
  id              String       @id @default(uuid())
  clienteNome     String
  clienteEndereco String
  formaPagamento  String
  total           Float
  status          String       @default("Pendente")
  criadoEm        DateTime     @default(now())
  itens           ItemPedido[]
}

model ItemPedido {
  id         String  @id @default(uuid())
  pedidoId   String
  produtoId  String
  nome       String
  preco      Float
  quantidade Int

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}
